# Copy to .env for local dev (never commit the real .env).

# Port the Go API listens on. Render/Fly inject this automatically.
PORT=8080

# CORS allow-list: the frontend origin the browser calls from.
# Local dev default is http://localhost:3000; in prod set your Vercel URL.
ALLOWED_ORIGIN=http://localhost:3000

# OpenAI API key — lives ONLY on the server, never in the frontend.
OPENAI_API_KEY=

# Optional: OpenAI model to use. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=gpt-4o-mini

# Optional: Cloudflare Turnstile SECRET key. If set, POST /api/analyze requires
# a valid Turnstile token (bot/abuse guard). Leave empty to disable (local dev).
TURNSTILE_SECRET=
